generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  // NOTICE: The url line is gone!
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  resumes   Resume[]
  createdAt DateTime @default(now())
}

model Resume {
  id        String   @id @default(cuid())
  title     String
  content   Json
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}